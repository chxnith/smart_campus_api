    {
      "name": "3. Sensors",
      "item": [
        {
          "name": "GET Sensors",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/sensors",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "sensors"
              ]
            }
          }
        },
        {
          "name": "GET Sensors Filtered By Type (CO2)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/sensors?type=CO2",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "sensors"
              ],
              "query": [
                {
                  "key": "type",
                  "value": "CO2"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const arr = pm.response.json();",
                  "pm.test('Response is an array', function () {",
                  "  pm.expect(Array.isArray(arr)).to.equal(true);",
                  "});",
                  "pm.test('All sensors have type CO2', function () {",
                  "  (arr || []).forEach(s => pm.expect((s.type || '').toLowerCase()).to.eql('co2'));",
                  "});"
                ]
              }
            }
          ]
        },
